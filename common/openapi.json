  "components": {
    "parameters": {
      "FileId": {
        "name": "fileId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uuid"
        }
      },
      "FolderId": {
        "name": "folderId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uuid"
        }
      },
      "GroupId": {
        "name": "groupId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uuid"
        }
      },
      "InviteId": {
        "name": "inviteId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uuid"
        }
      },
      "ShareId": {
        "name": "shareId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uuid"
        }
      },
      "EntryId": {
        "name": "entryId",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    "schemas": {
      "ApiError": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "error": {
            "type": "string"
          }
        }
      },
      "RegisterRequest": {
        "type": "object",
        "required": [
          "email",
          "display_name",
          "password",
          "public_key"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "display_name": {
            "type": "string"
          },
          "password": {
            "type": "string",
            "format": "password"
          },
          "public_key": {
            "type": "string"
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": [
          "email",
          "password"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string",
            "format": "password"
          },
          "remember": {
            "type": "boolean"
          }
        }
      },
      "RegisterResponse": {
        "type": "object",
        "required": [
          "id"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "TokenPair": {
        "type": "object",
        "required": [
          "access_token",
          "expires_in"
        ],
        "properties": {
          "access_token": {
            "type": "string"
          },
          "expires_in": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "CurrentUser": {
        "type": "object",
        "required": [
          "id",
          "email",
          "display_name",
          "avatar_url",
          "public_key",
          "default_view",
          "layout_mode",
          "upload_protection",
          "compact_metadata",
          "device_lock",
          "sync_on_metered",
          "trash_retention_days"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "display_name": {
            "type": "string",
            "nullable": true
          },
          "avatar_url": {
            "type": "string",
            "nullable": true
          },
          "public_key": {
            "type": "string",
            "nullable": true
          },
          "default_view": {
            "type": "string"
          },
          "layout_mode": {
            "type": "string"
          },
          "upload_protection": {
            "type": "boolean"
          },
          "compact_metadata": {
            "type": "boolean"
          },
          "device_lock": {
            "type": "boolean"
          },
          "sync_on_metered": {
            "type": "boolean"
          },
          "trash_retention_days": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "UserSettingsRequest": {
        "type": "object",
        "properties": {
          "display_name": {
            "type": "string",
            "nullable": true
          },
          "avatar_url": {
            "type": "string",
            "nullable": true
          },
          "default_view": {
            "type": "string"
          },
          "layout_mode": {
            "type": "string"
          },
          "upload_protection": {
            "type": "boolean"
          },
          "compact_metadata": {
            "type": "boolean"
          },
          "device_lock": {
            "type": "boolean"
          },
          "sync_on_metered": {
            "type": "boolean"
          },
